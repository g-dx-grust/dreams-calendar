# Lark OAuth
# https://open.feishu.cn / https://open.larksuite.com で発行
LARK_APP_ID=cli_xxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Feishu(中国) は https://open.feishu.cn/open-apis、Lark(国際) は https://open.larksuite.com/open-apis
LARK_OPEN_API_BASE=https://open.larksuite.com/open-apis
NEXT_PUBLIC_LARK_REDIRECT_URI=http://localhost:3000/api/auth/lark/callback
LARK_CALENDAR_ID=
LARK_SYNC_SECRET=
# Lark側で作成された新規予定を割り当てる既定社員ID。未設定時は先頭社員へ割り当て。
LARK_SYNC_DEFAULT_USER_ID=

# Supabase（kanri-system と共有プロジェクト：ref = etngtsqidqndmwmosrff）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# kanri-system 連携
KANRI_SYSTEM_URL=http://localhost:3001
NEXT_PUBLIC_KANRI_SYSTEM_URL=http://localhost:3001
KANRI_CALENDAR_API_SECRET=

# セッション暗号化
SESSION_SECRET=please-change-to-32+chars-random
